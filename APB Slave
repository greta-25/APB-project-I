module apb_slave #(parameter ADDR_WIDTH =8, parameter DATA_WIDTH =32)(
	input logic PCLK,
  	input logic PRESETn,
  input logic[ADDR_WIDTH-1:0] PADDR,
  input logic   PSEL,
  	input logic PENABLE,
  	input logic PWRITE,
  input logic[DATA_WIDTH-1:0] PWDATA,
  output logic[DATA_WIDTH-1:0] PRDATA,
  output logic PREADY,
  output logic PSLVERR

);
  
  logic [DATA_WIDTH-1:0] regs[0:3];
  logic valid_addr;
  assign valid_addr=(PADDR<= 2'b11);
  
  always_ff @(posedge PCLK or negedge PRESETn)begin
    
    if(!PRESETn)
      begin
        regs[0]<=0;
        regs[1]<=0;
        regs[2]<=0;
        regs[3]<=0;
      end
    else begin
      if(valid_addr && PENABLE && PSEL && PWRITE)
        begin
          regs[PADDR]<=PWDATA;
        end
    end
  end
  
  assign PRDATA= (PSEL && !PWRITE)?regs[PADDR]:0;
  assign PREADY=(PSEL & PENABLE)?1:0;
  assign PSLVERR=(PSEL&&PENABLE&& !valid_addr)?1:0;
endmodule
  

interface apb_if #(parameter ADDR_WIDTH =8, parameter DATA_WIDTH=32)(input logic PCLK);
	logic PRESETn;
	logic[ADDR_WIDTH-1:0] PADDR;
 	logic   PSEL;
  	logic PENABLE;
 	logic PWRITE;
 	logic[DATA_WIDTH-1:0] PWDATA;
  	logic[DATA_WIDTH-1:0] PRDATA;
  	logic PREADY;
  	logic PSLVERR;
  
  clocking cb @(posedge PCLK);
    default input #1;
    default output #1;
    input  PRDATA;
    input  PREADY;
    input  PSLVERR;
    
    output  PRESETn;
    output  PADDR;
    output  PSEL;
    output  PENABLE;
    output  PWRITE;
    output   PWDATA;
    
    
  endclocking
  
  modport tb(
  clocking cb,
    input PCLK
  
  );
  
    modport dut(
      input PCLK,
    input  PRESETn,
      input   PADDR,
    input  PSEL,
    input  PENABLE,
    input  PWRITE,
      input   PWDATA,
    
      output PRDATA,
    output  PREADY,
    output  PSLVERR
    
    property penable_after_psel;
      @(posedge PCLK)
      (PSEL && !PENABLE)|=>PENABLE;
    endproperty
      
      assert property(penable_after_psel);
    
        
        property psel_with_penable;
          @(posedge PCLK)
          disable iff(!PRESETn)
          PENABLE|->PSEL;
        endproperty
        assert property(psel_with_penable);
          
          
          property paddr_stable;
            @(posedge PCLK)
            disable iff(!PRESETn)
            (PSEL && PENABLE)|->$stable(PADDR);
          endproperty
          assert property(paddr_stable);
    
            property pslverr_valid;
              @(posedge PCLK)
              disable iff(!PRESETn)
              PSLVERR |-> (PSEL && PENABLE);
            endproperty
            assert property(pslverr_valid);
              
              property prdata_valid;
                @(posedge PCLK)
                disable iff(!PRESETn)
                (PSEL && PENABLE && !PWRITE && PREADY)|-> !$isunknown(PRDATA);
              endproperty
              assert property(prdata_valid);
                
                property reset_check;
                  @(posedge PCLK)
                  $rose(PRESETn)|=>(!PREADY && !PSLVERR);
                endproperty
                assert property(reset_check);
              
    );
  
endinterface
    
    
